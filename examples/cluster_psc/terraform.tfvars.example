# OCM offline token. Prefer OSDGOOGLE_TOKEN env var.
#ocm_token = ""

# GCP project ID (required). Set via TF_VAR_gcp_project_id or uncomment:
#gcp_project_id = "my-gcp-project"

# Subnet name or CIDR for PSC service attachment (required)
psc_subnet = "psc-subnet"

# Cluster name (must match terraform/wif_config). Set via TF_VAR_cluster_name or uncomment:
#cluster_name = "my-psc-cluster"

# OpenShift version
openshift_version = "4.21.3"

# Additional machine pools (optional). PSC cluster has secure_boot; pools can use secure_boot = true.
# machine_pools = [
#   {
#     name                = "compute"
#     instance_type       = "n2-standard-4"
#     autoscaling_enabled = false
#     replicas            = 3
#     secure_boot         = true
#   }
# ]
