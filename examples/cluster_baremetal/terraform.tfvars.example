# OCM offline token. Prefer OSDGOOGLE_TOKEN env var for local dev:
# export OSDGOOGLE_TOKEN="your-token"
#ocm_token = ""

# GCP project ID for the cluster (required). Set via TF_VAR_gcp_project_id or uncomment:
#gcp_project_id = "my-gcp-project"

# Name of the OSD cluster (must match terraform/wif_config cluster_name). Set via TF_VAR_cluster_name or uncomment:
#cluster_name = "my-baremetal-cluster"

# OpenShift version (x.y.z)
openshift_version = "4.21.3"

# Cluster admin password. Omit or leave empty to auto-generate.
#admin_password = ""

# GCP region
gcp_region = "us-central1"

# Bare metal machine type (use osdgoogle_machine_types to find available types)
# compute_machine_type = "c3-standard-192-metal"

# Number of worker nodes
# compute_nodes = 3

# Single zone for bare metal (machine type must exist in zone; c3-*-metal in us-central1-a, not us-central1-b)
# availability_zone = "us-central1-a"

# Additional machine pools (optional). If autoscaling_enabled = true, set min_replicas and max_replicas. If false, set replicas.
# For bare metal types, set availability_zones to zones where the type exists. secure_boot must be false for *-metal.
# machine_pools = [
#   {
#     name                = "compute"
#     instance_type       = "n2-standard-4"
#     autoscaling_enabled = false
#     replicas            = 3
#     availability_zones  = ["us-central1-a", "us-central1-b", "us-central1-c"]
#   }
# ]

# GCP authentication: use Application Default Credentials
# gcloud auth application-default login
