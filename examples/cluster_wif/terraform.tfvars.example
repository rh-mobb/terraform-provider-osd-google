# OCM offline token. Prefer OSDGOOGLE_TOKEN env var for local dev:
# export OSDGOOGLE_TOKEN="your-token"
#ocm_token = ""

# GCP project ID for the cluster (required)
gcp_project_id = "my-gcp-project"

# Prefix for custom IAM roles in GCP. When null, uses cluster_name.
# Hyphens and underscores are stripped (OCM allows only alphanumeric).
#role_prefix = null

# Name of the OSD cluster
cluster_name = "my-wif-cluster"

# OpenShift version (x.y.z). Used for cluster and WIF; WIF roles use x.y only.
openshift_version = "4.21.3"

# Cluster admin password. Omit or leave empty to auto-generate.
#admin_password = ""

# GCP authentication: use Application Default Credentials for project lookup
# gcloud auth application-default login
